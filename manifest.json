{
  "manifest_version": 3,
  "name": "LinkedIn Referral Automator",
  "version": "1.0",
  "description": "Find employees at target companies, send referral requests, follow up after they connect.",
  "permissions": ["storage", "scripting", "alarms", "cookies", "tabs"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
